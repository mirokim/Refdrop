{
  "manifest_version": 3,
  "name": "RefDrop",
  "version": "0.1.0",
  "description": "Send any web image or video frame directly into PureRef. One click.",

  "permissions": [
    "contextMenus",
    "storage",
    "nativeMessaging",
    "scripting",
    "activeTab"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon363.png",
      "48": "icons/icon363.png",
      "128": "icons/icon363.png"
    }
  },

  "icons": {
    "16": "icons/icon363.png",
    "48": "icons/icon363.png",
    "128": "icons/icon363.png"
  },

  "web_accessible_resources": [
    {
      "resources": ["icons/icon45.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
